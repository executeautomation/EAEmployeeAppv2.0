@model EAEmployee.Net8.Models.Employee
@{
    ViewData["Title"] = "Create Employee";
}

<style>
    .form-page-header {
        display: flex; align-items: center; gap: 1rem; margin-bottom: 1.75rem;
    }
    .form-page-header .back-link {
        display: inline-flex; align-items: center; gap: .3rem;
        color: #6c757d; font-size: .88rem; text-decoration: none;
        border: 1px solid #dee2e6; border-radius: 8px; padding: .35rem .75rem;
        transition: background .15s, color .15s;
    }
    .form-page-header .back-link:hover { background: #f8f9fa; color: #212529; }
    .form-page-header h2 { font-size: 1.45rem; font-weight: 700; color: #212529; margin: 0; }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,.10);
        border: 1px solid #eee;
        overflow: hidden;
        max-width: 680px;
    }
    .form-card-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        padding: 1.5rem 2rem;
        display: flex; align-items: center; gap: 1rem;
    }
    .form-card-header .header-icon {
        width: 52px; height: 52px;
        background: rgba(255,255,255,.18);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; flex-shrink: 0;
    }
    .form-card-header h3 { color: #fff; font-size: 1.15rem; font-weight: 700; margin: 0; }
    .form-card-header p  { color: rgba(255,255,255,.65); font-size: .82rem; margin: 0; }
    .form-card-body { padding: 2rem; }

    .field-group { margin-bottom: 1.25rem; }
    .field-group label {
        font-weight: 600; font-size: .82rem;
        color: #444; text-transform: uppercase; letter-spacing: .04em;
        margin-bottom: .4rem; display: block;
    }
    .input-icon-wrap { position: relative; }
    .input-icon-wrap .fi {
        position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
        color: #adb5bd; font-size: 1rem; pointer-events: none;
    }
    .input-icon-wrap input,
    .input-icon-wrap select {
        padding-left: 2.6rem;
        border-radius: 9px; border: 1.5px solid #dee2e6;
        width: 100%; padding-top: .55rem; padding-bottom: .55rem;
        font-size: .95rem; transition: border-color .2s, box-shadow .2s;
    }
    .input-icon-wrap input:focus,
    .input-icon-wrap select:focus {
        border-color: #0d6efd; outline: none;
        box-shadow: 0 0 0 3px rgba(13,110,253,.13);
    }
    .salary-prefix { position: absolute; left: 0; top: 0; bottom: 0; width: 2.6rem;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; color: #1a6b3c; font-size: .95rem; }
    .field-hint { font-size: .77rem; color: #6c757d; margin-top: .3rem; }
    .validation-msg { font-size: .8rem; color: #dc3545; margin-top: .25rem; display: block; }

    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

    .form-actions { display: flex; gap: .75rem; padding-top: .5rem; margin-top: 1rem; border-top: 1px solid #f0f0f0; }
    .btn-submit {
        flex: 1; padding: .72rem;
        background: linear-gradient(135deg, #1a6b3c, #28a745);
        border: none; border-radius: 9px; color: #fff;
        font-weight: 700; font-size: .95rem; cursor: pointer;
        transition: opacity .2s, transform .1s;
    }
    .btn-submit:hover { opacity: .9; transform: translateY(-1px); }
    .btn-cancel {
        padding: .72rem 1.5rem;
        background: #f8f9fa; border: 1.5px solid #dee2e6;
        border-radius: 9px; color: #495057;
        font-weight: 600; font-size: .95rem; text-decoration: none;
        display: inline-flex; align-items: center; gap: .3rem;
        transition: background .15s;
    }
    .btn-cancel:hover { background: #e9ecef; color: #212529; }
    @@media (max-width: 540px) { .form-row-2 { grid-template-columns: 1fr; } }
</style>

<div class="form-page-header">
    <a asp-action="Index" class="back-link">&#8592; Back to List</a>
    <h2>Create New Employee</h2>
</div>

<div class="form-card">
    <div class="form-card-header">
        <div class="header-icon">&#128101;</div>
        <div>
            <h3>Employee Information</h3>
            <p>Fill in the details to register a new employee</p>
        </div>
    </div>
    <div class="form-card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="font-size:.85rem"></div>

            <div class="field-group">
                <label asp-for="Name">Full Name</label>
                <div class="input-icon-wrap">
                    <span class="fi">&#128100;</span>
                    <input asp-for="Name" placeholder="e.g. Jane Smith" />
                </div>
                <span asp-validation-for="Name" class="validation-msg"></span>
            </div>

            <div class="form-row-2">
                <div class="field-group">
                    <label asp-for="Age">Age</label>
                    <div class="input-icon-wrap">
                        <span class="fi">&#128197;</span>
                        <input asp-for="Age" placeholder="e.g. 30" type="number" min="18" max="100" />
                    </div>
                    <span asp-validation-for="Age" class="validation-msg"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Salary">Monthly Salary</label>
                    <div class="input-icon-wrap">
                        <span class="salary-prefix">$</span>
                        <input asp-for="Salary" placeholder="e.g. 5000" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="Salary" class="validation-msg"></span>
                </div>
            </div>

            <div class="form-row-2">
                <div class="field-group">
                    <label asp-for="DurationWorked">Duration Worked (months)</label>
                    <div class="input-icon-wrap">
                        <span class="fi">&#128197;</span>
                        <input asp-for="DurationWorked" placeholder="e.g. 24" type="number" min="0" />
                    </div>
                    <span asp-validation-for="DurationWorked" class="validation-msg"></span>
                </div>
                <div class="field-group">
                    <label asp-for="Grade">Grade</label>
                    <div class="input-icon-wrap">
                        <span class="fi">&#127942;</span>
                        <select asp-for="Grade">
                            <option value="">-- Select Grade --</option>
                            <option value="1">Junior</option>
                            <option value="2">Middle</option>
                            <option value="3">Senior</option>
                            <option value="4">C-Level</option>
                        </select>
                    </div>
                    <label asp-for="Email">Email Address</label>
                    <div class="input-icon-wrap">
                        <span class="fi">&#9993;</span>
                        <input asp-for="Email" placeholder="employee@company.com" type="email" />
                    </div>
                    <span asp-validation-for="Email" class="validation-msg"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">&#10003; Create Employee</button>
                <a asp-action="Index" class="btn-cancel">&#10005; Cancel</a>
            </div>
        </form>
    </div>
</div>

<!-- Duplicate Employee Modal -->
<div class="modal fade" id="duplicateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:16px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,.18);">
            <div style="background:linear-gradient(135deg,#dc3545 0%,#c82333 100%);padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem;">
                <div style="width:48px;height:48px;background:rgba(255,255,255,.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">&#9888;&#65039;</div>
                <div>
                    <h5 style="color:#fff;font-weight:700;margin:0;font-size:1.1rem;">Duplicate Employee Found</h5>
                    <p style="color:rgba(255,255,255,.75);margin:0;font-size:.82rem;">An employee with this email already exists</p>
                </div>
            </div>
            <div style="padding:1.75rem 2rem;">
                <div id="dupDetails" style="background:#f8f9fa;border-radius:12px;padding:1.25rem;border:1px solid #eee;">
                </div>
                <p style="margin:1.25rem 0 0;font-size:.85rem;color:#6c757d;">Please use a different email address or edit the existing employee record.</p>
            </div>
            <div style="padding:0 2rem 1.5rem;display:flex;gap:.75rem;justify-content:flex-end;">
                <button type="button" class="btn" data-bs-dismiss="modal"
                        style="background:#f8f9fa;border:1.5px solid #dee2e6;border-radius:9px;font-weight:600;padding:.5rem 1.25rem;">
                    Close
                </button>
                <a id="dupEditLink" href="#" class="btn"
                   style="background:linear-gradient(135deg,#0d6efd,#0a58ca);color:#fff;border:none;border-radius:9px;font-weight:600;padding:.5rem 1.25rem;">
                    &#9998; Edit Existing
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            var form = document.querySelector('form[action*="Create"]');
            form.addEventListener('submit', function (e) {
                if (!$(form).valid()) return;
                e.preventDefault();
                var formData = new FormData(form);
                $.ajax({
                    url: form.action,
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (resp) {
                        if (resp && resp.isDuplicate) {
                            var emp = resp.employee;
                            var grades = { 1: 'Junior', 2: 'Middle', 3: 'Senior', 4: 'C-Level' };
                            var html =
                                '<div style="display:grid;grid-template-columns:auto 1fr;gap:.5rem .75rem;font-size:.9rem;">' +
                                '<span style="font-weight:600;color:#495057;">&#128100; Name</span><span>' + $('<span>').text(emp.name).html() + '</span>' +
                                '<span style="font-weight:600;color:#495057;">&#9993; Email</span><span>' + $('<span>').text(emp.email).html() + '</span>' +
                                '<span style="font-weight:600;color:#495057;">&#128197; Age</span><span>' + emp.age + ' years</span>' +
                                '<span style="font-weight:600;color:#495057;">&#128176; Salary</span><span>$' + Number(emp.salary).toLocaleString() + '</span>' +
                                '<span style="font-weight:600;color:#495057;">&#128197; Duration</span><span>' + emp.durationWorked + ' months</span>' +
                                '<span style="font-weight:600;color:#495057;">&#127942; Grade</span><span>' + (grades[emp.grade] || emp.grade) + '</span>' +
                                '</div>';
                            $('#dupDetails').html(html);
                            $('#dupEditLink').attr('href', '/Employee/Edit/' + emp.id);
                            new bootstrap.Modal(document.getElementById('duplicateModal')).show();
                        } else {
                            window.location.href = '@Url.Action("Index")';
                        }
                    }
                });
            });
        })();
    </script>
}

